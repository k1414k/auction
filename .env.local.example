# Copy-safe local development settings.
# scripts/local-up.sh copies this file to .env.local automatically on first run.

# PostgreSQL container settings.
# If your computer already uses port 5432, change DATABASE_PORT to 5433.
DATABASE_NAME=products_api_development
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_PORT=5432

# Rails CORS origins for the local Next.js frontend and Nuxt admin.
FRONTEND_ORIGINS=http://localhost:3001,http://localhost:3003

# Rails host allow-list for Docker-internal server-to-server requests.
RAILS_INTERNAL_HOSTS=backend
