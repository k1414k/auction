# Copy this file to .env on the EC2 host and replace every value marked CHANGE_ME.

# Public domains. Point all A records to the EC2 public IP before starting Caddy.
FRONTEND_DOMAIN=auction.jongin.blog
ADMIN_DOMAIN=admin.jongin.blog
API_DOMAIN=api.jongin.blog
CADDY_EMAIL=admin@example.com

# Rails / backend
RAILS_ENV=production
RACK_ENV=production
RAILS_MASTER_KEY=CHANGE_ME
SECRET_KEY_BASE=CHANGE_ME
APP_HOST=api.jongin.blog
APP_PROTOCOL=https
RAILS_HOSTS=api.jongin.blog
RAILS_INTERNAL_HOSTS=backend
FRONTEND_ORIGINS=https://auction.jongin.blog,https://admin.jongin.blog
REQUIRE_MASTER_KEY=true
FORCE_SSL=false
ASSUME_SSL=true
RAILS_LOG_LEVEL=info
RAILS_MAX_THREADS=5

# Database. The default compose file runs PostgreSQL as the db service.
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=products_api_production
DATABASE_USER=postgres
DATABASE_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Active Storage. Use local for a single EC2 deployment, amazon for S3.
ACTIVE_STORAGE_SERVICE=local
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# Frontend. Browser-visible values should use public HTTPS URLs.
NEXT_PUBLIC_API_BASE_URL=https://api.jongin.blog
NEXT_PUBLIC_API_HOST=api.jongin.blog

# Admin. The current admin app calls Rails directly from the browser.
NUXT_PUBLIC_API_BASE=https://api.jongin.blog
